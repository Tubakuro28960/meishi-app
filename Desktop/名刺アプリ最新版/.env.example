# ──────────────────────────────────────────
# Supabase（必須）
# Project Settings > API で確認
# ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# スケジューラー専用（絶対に公開しないこと）
# Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ──────────────────────────────────────────
# Google Cloud Vision API（OCR機能に必須）
# GCP Console > APIs & Services > Credentials
# Cloud Vision API を有効化すること
# ──────────────────────────────────────────
GOOGLE_CLOUD_VISION_API_KEY=your-vision-api-key

# ──────────────────────────────────────────
# メール送信プロバイダ（予約送信に必須）
# ──────────────────────────────────────────
# 使用プロバイダを指定（現在対応: resend）
MAIL_PROVIDER=resend

# Resend（https://resend.com）
RESEND_API_KEY=your-resend-api-key
# 送信元アドレス（Resend で認証済みドメインのアドレスのみ使用可）
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ──────────────────────────────────────────
# スケジューラー認証シークレット（必須）
# POST /api/scheduler の Authorization ヘッダーに使用
# openssl rand -hex 32 などで生成した乱数文字列を設定
# ──────────────────────────────────────────
CRON_SECRET=your-random-secret-string
